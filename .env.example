# Wookiee Analytics — корневой .env
# Скопируй этот файл в .env и заполни реальными значениями

# Wildberries
# Кабинет ИП
WB_API_KEY_IP=eyJ...
# Кабинет ООО
WB_API_KEY_OOO=eyJ...
# ============================================================================

# Ozon
# Кабинет ИП
OZON_CLIENT_ID_IP=0000000
OZON_API_KEY_IP=00000000-0000-0000-0000-000000000000
# Кабинет ООО
OZON_CLIENT_ID_OOO=0000000
OZON_API_KEY_OOO=00000000-0000-0000-0000-000000000000
# ============================================================================

# MPSTATS
X-Mpstats-TOKEN=your-mpstats-token
# ============================================================================

# FINOLOG
FINOLOG_API_KEY=your-finolog-api-key
# ============================================================================

# Google Sheets Sync
# ============================================================================
GOOGLE_SERVICE_ACCOUNT_FILE=services/sheets_sync/credentials/google_sa.json
SPREADSHEET_ID=your-spreadsheet-id
user=your-service-account@project.iam.gserviceaccount.com
SYNC_TEST_MODE=false

# Мой склад
MOYSKLAD_TOKEN=your-moysklad-token

# Bitrix24 Rest API
Bitrix_rest_api=https://your-domain.bitrix24.ru/rest/1/your-webhook-key/
# ============================================================================
# Telegram Bot Configuration
# ============================================================================
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Канал/чат для алертов от server_autopull.sh (опционально)
TELEGRAM_ALERT_CHAT_ID=000000000

# ============================================================================
# AI API Keys
# ============================================================================
# OpenRouter (primary — единый провайдер для всех LLM-вызовов)
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...

# Claude (fallback - премиум, ~$0.02/запрос)
CLAUDE_API_KEY=sk-ant-api03-...

# ============================================================================
# PostgreSQL (финансовые данные WB и OZON)
# ============================================================================
DB_HOST=0.0.0.0
DB_PORT=6433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME_WB=pbi_wb_wookiee
DB_NAME_OZON=pbi_ozon_wookiee
# ============================================================================
# Supabase (товарная матрица для ABC-анализа)
# ============================================================================
SUPABASE_HOST=aws-1-region.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres.your-project-ref
SUPABASE_PASSWORD=your-supabase-password

# ============================================================================
# Notion (для сохранения отчетов)
# ============================================================================
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=00000000000000000000000000000000

# ============================================================================
# Admin (fallback для отправки отчётов, если нет авторизованных юзеров)
# ============================================================================
ADMIN_CHAT_ID=000000000

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
