# Wookiee Analytics — Environment Variables
# Скопируй в .env и заполни реальными значениями
# НИКОГДА не коммить .env с реальными данными

# ============================================================================
# Telegram Bots
# ============================================================================
# Олег — финансовый аналитик
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_PASSWORD_HASH=your_bcrypt_hash_here
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'password', bcrypt.gensalt()).decode())"

# Людмила — CRM-ассистент
LYUDMILA_BOT_TOKEN=your_lyudmila_bot_token_here

# ============================================================================
# AI API Keys
# ============================================================================
# z.ai (primary — дешёвый, ~$0.002/запрос)
ZAI_API_KEY=your_zai_api_key_here

# Claude (fallback — премиум, ~$0.02/запрос)
CLAUDE_API_KEY=your_claude_api_key_here

# OpenRouter (Kimi 2.5 для Ибрагима — дата-инженер)
OPENROUTER_API_KEY=your_openrouter_api_key_here
IBRAHIM_LLM_MODEL=moonshotai/kimi-k2

# ============================================================================
# PostgreSQL (финансовые данные WB и OZON, предоставляются подрядчиком)
# ============================================================================
DB_HOST=your-db-host
DB_PORT=6433
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME_WB=pbi_wb_wookiee
DB_NAME_OZON=pbi_ozon_wookiee

# ============================================================================
# PostgreSQL — Managed DB (Ибрагим, marketplace ETL)
# ============================================================================
MARKETPLACE_DB_HOST=your-marketplace-db-host
MARKETPLACE_DB_PORT=5432
MARKETPLACE_DB_NAME=wookiee_marketplace
MARKETPLACE_DB_USER=your_marketplace_user
MARKETPLACE_DB_PASSWORD=your_marketplace_password

# Переключатель источника данных: 'legacy' (read-only БД) | 'managed' (БД Ибрагима)
DATA_SOURCE=legacy

# ============================================================================
# Supabase (товарная матрица для ABC-анализа)
# ============================================================================
SUPABASE_HOST=your-supabase-host
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=your_supabase_user
SUPABASE_PASSWORD=your_supabase_password

# ============================================================================
# Wildberries API (двойные кабинеты ИП + ООО)
# ============================================================================
WB_API_KEY_IP=your_wb_api_key_ip
WB_API_KEY_OOO=your_wb_api_key_ooo

# ============================================================================
# OZON API (двойные кабинеты ИП + ООО)
# ============================================================================
OZON_CLIENT_ID_IP=your_ozon_client_id_ip
OZON_API_KEY_IP=your_ozon_api_key_ip
OZON_CLIENT_ID_OOO=your_ozon_client_id_ooo
OZON_API_KEY_OOO=your_ozon_api_key_ooo

# ============================================================================
# Google Sheets (синхронизация остатков и цен)
# ============================================================================
GOOGLE_SERVICE_ACCOUNT_FILE=services/sheets_sync/credentials/google_sa.json
SPREADSHEET_ID=your_spreadsheet_id

# ============================================================================
# МойСклад API
# ============================================================================
MOYSKLAD_TOKEN=your_moysklad_token

# ============================================================================
# Bitrix24 CRM (используется Людмилой)
# ============================================================================
Bitrix_rest_api=your_bitrix_rest_api_url

# ============================================================================
# Василий — логистика WB
# ============================================================================
VASILY_SPREADSHEET_ID=your_vasily_spreadsheet_id
VASILY_BITRIX_CHAT_ID=your_vasily_bitrix_chat_id
VASILY_BITRIX_FOLDER_ID=your_vasily_bitrix_folder_id

# ============================================================================
# Notion (для сохранения отчётов)
# ============================================================================
NOTION_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_notion_database_id

# ============================================================================
# Scheduling & Logging
# ============================================================================
SYNC_SCHEDULE=05:00
DAILY_REPORT_TIME=10:05
WEEKLY_REPORT_TIME=10:15
MONTHLY_REPORT_TIME=10:30
LOG_LEVEL=INFO

# ============================================================================
# Testing
# ============================================================================
SYNC_TEST_MODE=false
