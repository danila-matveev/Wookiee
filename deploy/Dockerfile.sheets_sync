FROM python:3.11-slim

WORKDIR /app

COPY services/sheets_sync/requirements.txt /app/services/sheets_sync/requirements.txt
RUN pip install --no-cache-dir -r services/sheets_sync/requirements.txt

COPY shared/ /app/shared/
COPY services/__init__.py /app/services/__init__.py
COPY services/sheets_sync/ /app/services/sheets_sync/

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["python", "-m", "services.sheets_sync.control_panel"]
